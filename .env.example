# Copy this file to .env and fill in secrets. .env is ignored by Git.

# Discord bot token (keep secret)
DISCORD_TOKEN=your_discord_token_here


# Google AI Studio (optional)
GOOGLE_API_KEY=your_google_ai_studio_api_key
# Set `GOOGLE_MODEL` only if using Google AI Studio.
GOOGLE_MODEL=
GOOGLE_MAX_CONCURRENCY=2
# Requests-per-second allowed for Google AI Studio (token-bucket). Default 1.0
GOOGLE_RPS=1.0

# Multi-provider support
# Set AI_PROVIDER to one of: google, openai, anthropic. If unset, the bot will auto-detect
# based on which API key you provide (OPENAI_API_KEY, ANTHROPIC_API_KEY, GOOGLE_API_KEY).
AI_PROVIDER=

# OpenAI (ChatGPT) API key and model (optional)
OPENAI_API_KEY=
OPENAI_MODEL=

# Anthropic (Claude) API key and model (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Database connection - prefer a single DATABASE_URL or individual DB_* vars
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=

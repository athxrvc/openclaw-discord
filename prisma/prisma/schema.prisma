generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Channel {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  name      String    @unique
  createdAt DateTime  @default(now())
  messages  Message[]
  summaries Summary[]
}

model Message {
  id          Int      @id @default(autoincrement())
  channelCode String
  channel     Channel  @relation(fields: [channelCode], references: [code])
  role        String
  content     String
  createdAt   DateTime @default(now())

  @@index([channelCode])
}

model Summary {
  id             Int      @id @default(autoincrement())
  channelCode    String
  channel        Channel  @relation(fields: [channelCode], references: [code])
  summary        String
  startMessageId Int
  endMessageId   Int
  createdAt      DateTime @default(now())

  @@index([channelCode])
}